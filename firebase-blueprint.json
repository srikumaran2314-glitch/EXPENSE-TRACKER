{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "mobile": { "type": "string", "description": "Mobile number" },
        "partnerId": { "type": "string", "description": "UID of the linked partner" },
        "partnerCode": { "type": "string", "description": "Unique code for linking" },
        "isAdmin": { "type": "boolean", "description": "Admin status" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"], "description": "User gender for theming" },
        "chatBackground": { "type": "string", "description": "Custom chat background URL or color" },
        "isTyping": { "type": "boolean", "description": "Whether the user is currently typing" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "partnerCode"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Shared expense record",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Creator UID" },
        "partnerId": { "type": "string", "description": "Partner UID at time of creation" },
        "amount": { "type": "number" },
        "paidBy": { "type": "string", "description": "Name of person who paid" },
        "paymentMode": { "type": "string" },
        "category": { "type": "string" },
        "paidTo": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "receiptUrl": { "type": "string", "description": "Base64 encoded file data" },
        "receiptName": { "type": "string", "description": "Name of the uploaded file" },
        "receiptType": { "type": "string", "description": "MIME type of the file" },
        "receivableFrom": { "type": "string", "description": "Name of person who owes this money back to the partners" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "category", "date"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Message between partners",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "photo", "video", "file", "voice"], "description": "Type of message content" },
        "expenseRefId": { "type": "string" },
        "voiceData": { "type": "string", "description": "Base64 encoded voice note" },
        "fileData": { "type": "string", "description": "Base64 encoded file data" },
        "fileName": { "type": "string", "description": "Name of the uploaded file" },
        "isOnceView": { "type": "boolean", "description": "Whether the media is view-once" },
        "viewedAt": { "type": "string", "format": "date-time", "description": "Timestamp when receiver viewed once-view media" },
        "read": { "type": "boolean", "description": "Whether the message has been read by receiver" },
        "isPinned": { "type": "boolean", "description": "Whether the message is pinned" },
        "reactions": { 
          "type": "object", 
          "description": "Emoji reactions map: { emoji: [userIds] }" 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notification for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Target user UID" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["chat", "expense", "reminder"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget for a category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "partnerId": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "string", "description": "YYYY-MM format" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "partnerId", "category", "amount", "month"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "Item the couple wants to buy or save for",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "partnerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "estimatedAmount": { "type": "number" },
        "savedAmount": { "type": "number" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "isCompleted": { "type": "boolean" },
        "imageUrl": { "type": "string", "description": "Base64 encoded image" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "partnerId", "title", "estimatedAmount"]
    },
    "Todo": {
      "title": "Todo",
      "description": "Shared task for the couple",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "partnerId": { "type": "string" },
        "task": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "dueDate": { "type": "string", "format": "date" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "partnerId", "task"]
    },
    "Salary": {
      "title": "Salary",
      "description": "User monthly salary and breakdown",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "breakdown": {
          "type": "object",
          "properties": {
            "Rent": { "type": "number" },
            "Food": { "type": "number" },
            "Travel": { "type": "number" },
            "Bills": { "type": "number" },
            "Savings": { "type": "number" },
            "Personal": { "type": "number" },
            "Others": { "type": "number" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount"]
    },
    "IncomeEntry": {
      "title": "IncomeEntry",
      "description": "Individual income record (salary, bonus, gift, etc.)",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User UID who received the income" },
        "source": { "type": "string", "enum": ["Salary", "Gift", "Bonus", "Other"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "source", "amount", "date"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Shared expenses"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Partner chat messages"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Category budgets"
    },
    "wishlist/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "Shared wishlist items"
    },
    "todos/{todoId}": {
      "schema": "Todo",
      "description": "Shared tasks"
    },
    "salaries/{userId}": {
      "schema": "Salary",
      "description": "User salary and breakdown"
    },
    "income_entries/{entryId}": {
      "schema": "IncomeEntry",
      "description": "Individual income records"
    }
  }
}
